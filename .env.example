# ===== 宏达新媒体作战中台 - 环境变量说明 =====
#
# 命名规则:
#   NEXT_PUBLIC_*   = 公开变量，可被浏览器端代码访问
#   无前缀           = 服务端变量，不可被浏览器端访问
#                     (在 .next/static/ 中搜索会触发 CI 失败)
#
# ===== Supabase (两者都需要 NEXT_PUBLIC_ 前缀) =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== OpenAI =====
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ===== 微信开放平台 (服务端密钥) =====
WECHAT_VIDEO_ACCESS_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ===== 抖音开放平台 (服务端密钥) =====
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=

# ===== 应用配置 (公开) =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
